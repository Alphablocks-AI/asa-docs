{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Asa Docs",
  "colors": {
    "primary": "#0e0e0e",
    "light": "#0e0e0e",
    "dark": "#0e0e0e"
  },
  "fonts": {
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "favicon": "/icon.png",
  "icons": {
    "library": "fontawesome"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "get-started/add-manage-knowledge",
          "get-started/customize",
          "get-started/deploy",
          "get-started/manage-conversations",
          "get-started/analytics"
        ]
      },
      {
        "group": "Integrations",
        "pages": [
          "integrations/shopify",
          "integrations/notion",
          "integrations/judge-me",
          "integrations/yotpo",
          "integrations/google-drive",
          "integrations/klaviyo"
        ]
      },
      {
        "group": "Resources",
        "pages": [
          "resources/plan-pricing",
          "resources/best-practices",
          "resources/trained-source-count"
        ]
      },
      {
        "group": "Legal",
        "pages": [
          "legal/terms-of-service",
          "legal/privacy",
          "legal/cookies",
          "legal/fair-usage",
          "legal/asa-limitations",
          "legal/refunds"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://asa.so",
          "icon": "globe"
        },
        {
          "anchor": "Blog",
          "href": "https://asa.so/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@alphablocks.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://asa.alphablocks.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/AlphablocksAI",
      "linkedin": "https://www.linkedin.com/company/alphablocks",
      "instagram": "https://www.instagram.com/alphablocksai/"
    }
  }
}